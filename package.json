{
  "name": "elog-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "devDependencies": {
    "@changesets/cli": "^2.29.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.5.0",
    "prettier": "^3.8.3",
    "turbo": "^2.5.0"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": "prettier --write"
  },
  "scripts": {
    "build": "turbo build",
    "test": "turbo test --filter=!@elogx-test/e2e",
    "changeset": "changeset",
    "version": "changeset version",
    "publish": "changeset publish",
    "prepare": "husky",
    "e2e": "pnpm --filter @elogx-test/e2e e2e",
    "e2e:cli": "pnpm --filter @elogx-test/e2e test:cli",
    "e2e:yuque-local": "pnpm --filter @elogx-test/e2e test:yuque-local"
  }
}
