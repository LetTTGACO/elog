{
  "$schema": "./plugin-registry.schema.json",
  "schemaVersion": 1,
  "plugins": [
    {
      "kind": "from",
      "type": "notion",
      "displayName": "Notion",
      "packageName": "@elog/plugin-from-notion",
      "importName": "notion",
      "optionsSchema": {
        "type": "object",
        "required": ["token"],
        "properties": {
          "token": {
            "type": "string",
            "title": "Notion Token",
            "x-elog-env": "NOTION_TOKEN",
            "x-elog-secret": true,
            "x-elog-prompt": {
              "type": "password",
              "message": "请输入 Notion Token"
            }
          },
          "dataSourceId": {
            "type": "string",
            "title": "Notion Data Source ID",
            "x-elog-env": "NOTION_DATA_SOURCE_ID",
            "x-elog-prompt": {
              "type": "input",
              "message": "请输入 Notion Data Source ID"
            }
          },
          "databaseId": {
            "type": "string",
            "title": "Notion Database ID",
            "x-elog-env": "NOTION_DATABASE_ID",
            "x-elog-prompt": {
              "type": "input",
              "message": "请输入 Notion Database ID"
            }
          }
        },
        "additionalProperties": false
      }
    },
    {
      "kind": "from",
      "type": "yuque-token",
      "displayName": "语雀（Token 模式）",
      "packageName": "@elog/plugin-from-yuque-token",
      "importName": "yuqueToken",
      "optionsSchema": {
        "type": "object",
        "required": ["token", "login", "repo"],
        "properties": {
          "token": {
            "type": "string",
            "title": "语雀 Token",
            "x-elog-env": "YUQUE_TOKEN",
            "x-elog-secret": true,
            "x-elog-prompt": {
              "type": "password",
              "message": "请输入语雀 Token"
            }
          },
          "login": {
            "type": "string",
            "title": "语雀用户名",
            "x-elog-env": "YUQUE_LOGIN",
            "x-elog-prompt": {
              "type": "input",
              "message": "请输入语雀用户名"
            }
          },
          "repo": {
            "type": "string",
            "title": "语雀知识库路径",
            "x-elog-env": "YUQUE_REPO",
            "x-elog-prompt": {
              "type": "input",
              "message": "请输入语雀知识库路径"
            }
          },
          "onlyPublic": {
            "type": "boolean",
            "title": "只同步公开文章",
            "default": false,
            "x-elog-prompt": {
              "type": "confirm",
              "message": "是否只同步公开文章？"
            }
          },
          "onlyPublished": {
            "type": "boolean",
            "title": "只同步已发布文档",
            "default": false,
            "x-elog-prompt": {
              "type": "confirm",
              "message": "是否只同步已发布文档？"
            }
          },
          "limit": {
            "type": "number",
            "title": "下载并发数",
            "x-elog-prompt": {
              "type": "number",
              "message": "请输入下载并发数"
            }
          }
        },
        "additionalProperties": false
      }
    },
    {
      "kind": "from",
      "type": "yuque-pwd",
      "displayName": "语雀（账号密码模式）",
      "packageName": "@elog/plugin-from-yuque-pwd",
      "importName": "fromYuque",
      "optionsSchema": {
        "type": "object",
        "required": ["username", "password", "login", "repo"],
        "properties": {
          "username": {
            "type": "string",
            "title": "语雀账号",
            "x-elog-env": "YUQUE_USERNAME",
            "x-elog-prompt": {
              "type": "input",
              "message": "请输入语雀账号"
            }
          },
          "password": {
            "type": "string",
            "title": "语雀密码",
            "x-elog-env": "YUQUE_PWD",
            "x-elog-secret": true,
            "x-elog-prompt": {
              "type": "password",
              "message": "请输入语雀密码"
            }
          },
          "login": {
            "type": "string",
            "title": "语雀用户名",
            "x-elog-env": "YUQUE_LOGIN",
            "x-elog-prompt": {
              "type": "input",
              "message": "请输入语雀用户名"
            }
          },
          "repo": {
            "type": "string",
            "title": "语雀知识库路径",
            "x-elog-env": "YUQUE_REPO",
            "x-elog-prompt": {
              "type": "input",
              "message": "请输入语雀知识库路径"
            }
          },
          "latexCode": {
            "type": "boolean",
            "title": "转换语雀 LaTeX 公式",
            "default": false,
            "x-elog-prompt": {
              "type": "confirm",
              "message": "是否转换语雀 LaTeX 公式？"
            }
          },
          "onlyPublic": {
            "type": "boolean",
            "title": "只同步公开文章",
            "default": false,
            "x-elog-prompt": {
              "type": "confirm",
              "message": "是否只同步公开文章？"
            }
          }
        },
        "additionalProperties": false
      }
    },
    {
      "kind": "from",
      "type": "feishu-wiki",
      "displayName": "飞书 Wiki",
      "packageName": "@elog/plugin-from-feishu-wiki",
      "importName": "fromFeishuWiki",
      "optionsSchema": {
        "type": "object",
        "required": ["appId", "appSecret", "wikiId"],
        "properties": {
          "appId": {
            "type": "string",
            "title": "飞书 App ID",
            "x-elog-env": "FEISHU_APP_ID",
            "x-elog-prompt": {
              "type": "input",
              "message": "请输入飞书 App ID"
            }
          },
          "appSecret": {
            "type": "string",
            "title": "飞书 App Secret",
            "x-elog-env": "FEISHU_APP_SECRET",
            "x-elog-secret": true,
            "x-elog-prompt": {
              "type": "password",
              "message": "请输入飞书 App Secret"
            }
          },
          "wikiId": {
            "type": "string",
            "title": "飞书知识库 ID",
            "x-elog-env": "FEISHU_WIKI_ID",
            "x-elog-prompt": {
              "type": "input",
              "message": "请输入飞书知识库 ID"
            }
          },
          "folderToken": {
            "type": "string",
            "title": "飞书知识库节点 Token",
            "x-elog-env": "FEISHU_WIKI_FOLDER_TOKEN",
            "x-elog-prompt": {
              "type": "input",
              "message": "请输入飞书知识库节点 Token"
            }
          },
          "disableParentDoc": {
            "type": "boolean",
            "title": "跳过父级文档",
            "default": false,
            "x-elog-prompt": {
              "type": "confirm",
              "message": "父级文档下存在子文档时，是否跳过父级文档？"
            }
          },
          "baseUrl": {
            "type": "string",
            "title": "飞书 API Base URL",
            "x-elog-env": "FEISHU_BASE_URL",
            "x-elog-prompt": {
              "type": "input",
              "message": "请输入飞书 API Base URL"
            }
          }
        },
        "additionalProperties": false
      }
    },
    {
      "kind": "from",
      "type": "feishu-space",
      "displayName": "飞书云空间",
      "packageName": "@elog/plugin-from-feishu-space",
