{
  "name": "elog-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "packageManager": "pnpm@11.1.2",
  "devDependencies": {
    "@nx/js": "^23.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "nx": "^23.0.1",
    "prettier": "^3.9.4"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": "prettier --write"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "typecheck": "nx run-many -t typecheck",
    "test": "nx run-many -t test --exclude=@elog/e2e",
    "release:beta:dry-run": "NPM_CONFIG_TAG=beta nx release --dry-run --preid=beta",
    "release:beta": "NPM_CONFIG_TAG=beta nx release --preid=beta --yes",
    "release:dry-run": "nx release --dry-run",
    "release": "nx release --yes",
    "prepare": "husky",
    "e2e": "pnpm --filter @elog/e2e e2e",
    "e2e:cli": "pnpm --filter @elog/e2e test:cli",
    "e2e:feishu-wiki-local": "pnpm --filter @elog/e2e test:feishu-wiki-local",
    "e2e:feishu-space-r2-local": "pnpm --filter @elog/e2e test:feishu-space-r2-local",
    "e2e:notion-local": "pnpm --filter @elog/e2e test:notion-local",
    "e2e:yuque-pwd-local": "pnpm --filter @elog/e2e test:yuque-pwd-local",
    "e2e:yuque-token-local": "pnpm --filter @elog/e2e test:yuque-token-local",
    "e2e:notion-wordpress": "pnpm --filter @elog/e2e test:notion-wordpress",
    "e2e:notion-halo": "pnpm --filter @elog/e2e test:notion-halo"
  }
}
