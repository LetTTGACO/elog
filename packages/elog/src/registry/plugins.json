          "appSecret": {
            "type": "string",
            "title": "飞书 App Secret",
            "x-elog-env": "FEISHU_APP_SECRET",
            "x-elog-secret": true,
            "x-elog-prompt": {
              "type": "password",
              "message": "请输入飞书 App Secret"
            }
          },
          "folderToken": {
            "type": "string",
            "title": "飞书文件夹 Token",
            "x-elog-env": "FEISHU_SPACE_FOLDER_TOKEN",
            "x-elog-prompt": {
              "type": "input",
              "message": "请输入飞书文件夹 Token"
            }
          },
          "baseUrl": {
            "type": "string",
            "title": "飞书 API Base URL",
            "x-elog-env": "FEISHU_BASE_URL",
            "x-elog-prompt": {
              "type": "input",
              "message": "请输入飞书 API Base URL"
            }
          }
        },
        "additionalProperties": false
      }
